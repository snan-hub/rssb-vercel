{
  "version": 2,
  "routes": [
    { "src": "/api/autoscan", "dest": "/api/autoscan.js" },
    { "src": "/api/videos(.*)", "dest": "/api/videos.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/scan-log", "dest": "/api/scan-log.js" },
    { "src": "/api/export", "dest": "/api/export.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
